{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#0078D4",
          "template": "{{ if .WSL }}WSL {{ end }}{{ .Icon }} ",
          "options": {
            "windows": "\uf17a"
          }
        },
        {
          "background": "#008F11",
          "foreground": "#00FF41",
          "style": "powerline",
          "leading_powerline_symbol": "\ue0b6",
          "powerline_symbol": "\ue0b0",
          "template": " Hennie Francis ",
          "type": "session",
          "properties": {
            "style": "bold"
          }
        },
        {
          "background": "#6F2DA8",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path",
          "properties": {
	  "style": "full",
	  "folder_separator_icon": " <#00FF41>\ue0b1</> "
          }
        },
        {
          "background": "#95ffa4",
          "foreground": "#193549",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " {{ .HEAD }} ",
          "type": "git"
        },
        {
          "background": "#FF6471",
          "foreground": "#ffffff",
          "leading_diamond": "<transparent,background>\ue0b0</>",
          "style": "diamond",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0b4",
          "type": "python"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
